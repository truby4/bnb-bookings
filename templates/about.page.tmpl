{{template "base" .}} {{define "content"}}
<div class="container">
    <div class="row">
        <div class="col">
            <h1>Welcome to the about page</h1>
            <p class="lead">
                This is some kind of description on my About
                page
            </p>

            <p>
                This came from the templateData: {{index
                .StringMap "test"}}
            </p>
            <p>
                {{if ne (index .StringMap "remote_ip") ""}}
                Your remote IP address is {{index .StringMap
                "remote_ip"}} {{else}} I don't know your IP
                address yet. Visit the
                <a href="/">Home Page</a> so i can set it in
                sessions. {{end}}
            </p>
        </div>
    </div>
</div>
{{end}}
